#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git Pre-push Hook (优化版)
推送前运行完整测试套件
- 实时输出测试结果
- 超时 10 分钟
- 使用 -x 在第一次失败时停止（节省时间）
"""
import subprocess
import sys
import os


def get_project_root() -> str:
    """获取项目根目录"""
    hook_dir = os.path.dirname(os.path.abspath(__file__))
    return os.path.dirname(os.path.dirname(hook_dir))


def run_tests_live(cmd: list, timeout: int = 600) -> tuple:
    """运行测试并实时输出"""
    try:
        process = subprocess.Popen(
            cmd,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
            cwd=get_project_root(),
            bufsize=1
        )

        output_lines = []
        for line in process.stdout:
            print(line, end='')
            output_lines.append(line)

        process.wait(timeout=timeout)
        return process.returncode, ''.join(output_lines)

    except subprocess.TimeoutExpired:
        process.kill()
        return -1, f"Timeout after {timeout}s"
    except Exception as e:
        return 1, str(e)


def main():
    """主函数"""
    print("=" * 60)
    print("Git Pre-push 测试")
    print("=" * 60)

    venv_pytest = os.path.join(get_project_root(), '.venv', 'bin', 'pytest')

    if os.path.exists(venv_pytest):
        # 跳过 e2e 和 slow 测试，只运行单元测试
        cmd = [
            venv_pytest,
            "tests/",
            "-v", "--tb=short", "--timeout=60", "-x",
            "-m", "not e2e and not slow"  # 跳过 e2e 和 slow 标记的测试
        ]
        print(f"使用虚拟环境 pytest")
    else:
        cmd = [
            "python", "-m", "pytest", "tests/",
            "-v", "--tb=short", "--timeout=60", "-x",
            "-m", "not e2e and not slow"
        ]
        print("使用系统 pytest")

    print(f"运行单元测试（跳过 e2e/slow，超时 5 分钟）...")
    print("-" * 60)

    code, output = run_tests_live(cmd, timeout=300)

    print("-" * 60)

    if code == 0:
        print("✓ 所有测试通过，允许推送")
        sys.exit(0)
    elif code == -1:
        print("❌ 测试超时（10 分钟），推送被阻止")
        print("\n建议:")
        print("  1. git push --no-verify 跳过测试")
        print("  2. 本地运行测试查看详细")
        sys.exit(1)
    else:
        print("❌ 测试失败，推送被阻止")
        sys.exit(1)


if __name__ == "__main__":
    main()
