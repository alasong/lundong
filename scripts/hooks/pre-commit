#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Git Pre-commit Hook (快速版)
提交前检查：
1. 只检查暂存文件的语法和敏感信息
2. 只运行与修改文件相关的测试（超时 30 秒）
"""
import subprocess
import sys
import re
import os
from pathlib import Path
from typing import List, Set, Tuple


# 配置
TEST_TIMEOUT = 30  # 测试超时时间（秒）
SYNTAX_TIMEOUT = 10  # 语法检查超时时间（秒）


def get_project_root() -> str:
    """获取项目根目录"""
    git_dir = os.path.dirname(os.path.abspath(__file__))
    return os.path.dirname(os.path.dirname(git_dir))


def run_command(cmd: list, timeout: int = TEST_TIMEOUT, cwd: str = None) -> Tuple[int, str, str]:
    """运行命令并返回结果"""
    try:
        result = subprocess.run(
            cmd, capture_output=True, text=True,
            timeout=timeout, cwd=cwd or get_project_root()
        )
        return result.returncode, result.stdout, result.stderr
    except subprocess.TimeoutExpired:
        return -1, "", f"⚠ Timeout after {timeout}s (跳过)"
    except Exception as e:
        return 1, "", str(e)


def get_staged_files() -> List[str]:
    """获取暂存的文件列表"""
    code, stdout, _ = run_command(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        timeout=5
    )
    if code != 0:
        return []
    return [f.strip() for f in stdout.split('\n') if f.strip()]


def check_python_syntax(files: List[str]) -> bool:
    """快速检查 Python 语法"""
    python_files = [f for f in files if f.endswith('.py')]
    if not python_files:
        return True

    errors = []
    for f in python_files:
        full_path = os.path.join(get_project_root(), f)
        if os.path.exists(full_path):
            code, _, stderr = run_command(
                [sys.executable, "-m", "py_compile", full_path],
                timeout=SYNTAX_TIMEOUT
            )
            if code != 0:
                errors.append(f"{f}: {stderr.strip()}")

    if errors:
        print(f"❌ 语法检查失败 ({len(errors)} 个文件):")
        for e in errors[:5]:  # 只显示前 5 个错误
            print(f"  {e}")
        return False

    print(f"✓ 语法检查通过 ({len(python_files)} 个文件)")
    return True


def check_sensitive_data(files: List[str]) -> bool:
    """快速检查敏感数据"""
    patterns = [
        (r'AKIA[0-9A-Z]{16}', 'AWS Key'),
        (r'ghp_[a-zA-Z0-9]{36}', 'GitHub Token'),
        (r'sk-[a-zA-Z0-9]{48}', 'API Key'),
    ]

    errors = []
    for f in files:
        if f.endswith('.py') and not any(x in f for x in ['test', 'example', 'sample']):
            full_path = os.path.join(get_project_root(), f)
            if os.path.exists(full_path):
                try:
                    with open(full_path, 'r', encoding='utf-8') as fp:
                        content = fp.read()
                        for pattern, desc in patterns:
                            if re.search(pattern, content, re.IGNORECASE):
                                errors.append(f"{f}: {desc}")
                except:
                    pass

    if errors:
        print(f"❌ 敏感信息检查失败:")
        for e in errors:
            print(f"  {e}")
        return False

    print("✓ 敏感信息检查通过")
    return True


def get_related_tests(files: List[str]) -> Set[str]:
    """智能获取相关测试文件"""
    # 文件到测试的映射
    file_to_test = {
        'predictor.py': 'test_prediction.py',
        'predict_agent.py': 'test_prediction.py',
        'analysis_agent.py': 'test_analysis.py',
        'data_agent.py': 'test_data_collection.py',
        'hotspot_detector.py': 'test_analysis.py',
        'rotation_analyzer.py': 'test_analysis.py',
        'fast_collector.py': 'test_data_collection.py',
        'database.py': 'test_database.py',
        'data_organizer.py': 'test_data_collection.py',
        'storage_manager.py': 'test_data_collection.py',
        'main.py': 'test_e2e_pipeline.py',
        'runner.py': 'test_e2e_pipeline.py',
    }

    related = set()
    for f in files:
        filename = os.path.basename(f)

        # 如果修改的是测试文件，直接运行
        if f.startswith('tests/'):
            related.add(f)
        elif filename in file_to_test:
            test_file = f"tests/{file_to_test[filename]}"
            if os.path.exists(os.path.join(get_project_root(), test_file)):
                related.add(test_file)
            # 也运行通用测试
            related.add("tests/test_prediction.py")

    return related


def run_tests(test_files: Set[str]) -> bool:
    """运行指定的测试"""
    if not test_files:
        print("✓ 无相关测试，跳过")
        return True

    # 检查文件是否存在
    existing_tests = [t for t in test_files if os.path.exists(os.path.join(get_project_root(), t))]
    if not existing_tests:
        print("✓ 测试文件不存在，跳过")
        return True

    print(f"运行测试：{len(existing_tests)} 个文件")

    venv_pytest = os.path.join(get_project_root(), '.venv', 'bin', 'pytest')
    cmd = [venv_pytest if os.path.exists(venv_pytest) else "python", "-m", "pytest"]
    cmd.extend(existing_tests)
    cmd.extend(["-x", "-q", "--tb=line", "-m", "not e2e and not slow"])

    code, stdout, stderr = run_command(cmd, timeout=TEST_TIMEOUT)

    # 解析结果
    for line in stdout.split('\n') + stderr.split('\n'):
        if 'passed' in line.lower():
            print(f"✓ {line.strip()}")
            return code == 0
        if 'failed' in line.lower() or 'error' in line.lower():
            if code != 0:
                print(f"❌ {line.strip()}")

    return code == 0


def main():
    """主函数"""
    staged_files = get_staged_files()
    if not staged_files:
        sys.exit(0)

    # 1. 语法检查
    if not check_python_syntax(staged_files):
        sys.exit(1)

    # 2. 敏感信息检查
    if not check_sensitive_data(staged_files):
        sys.exit(1)

    # 3. 运行相关测试
    related_tests = get_related_tests(staged_files)
    if not run_tests(related_tests):
        print("\n❌ 测试失败，请修复后重新提交")
        print("提示：使用 git commit --no-verify 跳过测试（不推荐）")
        sys.exit(1)

    print("\n✓ Pre-commit 检查通过")
    sys.exit(0)


if __name__ == "__main__":
    main()
